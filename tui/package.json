{
  "name": "aplica-ai-tui",
  "version": "1.0.0",
  "description": "Aplica AI — Terminal User Interface (TUI) built with Ink",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "aplica-tui": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx --watch src/index.tsx",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
