{
  "name": "aplica-ai-desktop",
  "version": "1.0.0",
  "description": "Aplica AI – Desktop Agent powered by Electron",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -n VITE,ELECTRON -c cyan,magenta \"vite\" \"wait-on tcp:3001 && tsc -p tsconfig.electron.json && electron .\"",
    "electron:build:win": "vite build && tsc -p tsconfig.electron.json && electron-builder --win",
    "electron:build:mac": "vite build && tsc -p tsconfig.electron.json && electron-builder --mac",
    "electron:build:linux": "vite build && tsc -p tsconfig.electron.json && electron-builder --linux",
    "electron:build": "vite build && tsc -p tsconfig.electron.json && electron-builder",
    "tsc:electron": "tsc -p tsconfig.electron.json"
  },
  "dependencies": {
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "reactflow": "^11.11.4",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.2.1",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "ai.aplica.desktop",
    "productName": "Aplica AI",
    "copyright": "Copyright © 2025 Aplica AI",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "public/**/*"
    ],
    "win": {
      "icon": "public/icon.png",
      "target": ["nsis", "portable"]
    },
    "mac": {
      "icon": "public/icon.png",
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"]
    },
    "linux": {
      "icon": "public/icon.png",
      "target": ["AppImage", "deb"],
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
